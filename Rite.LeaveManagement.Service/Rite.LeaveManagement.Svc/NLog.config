<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

	<variable name="layout"
			  value="${longdate}|${uppercase:${level}}|${logger}|corr=${scopeproperty:CorrelationId}|${message} ${exception:format=tostring}" />

	<targets>
		<target xsi:type="File" name="file"
				fileName="${basedir}/logs/${shortdate}.log"
				archiveFileName="${basedir}/logs/archives/${date:format=yyyy-MM}/${shortdate}.log"
				archiveEvery="Day"
				archiveNumbering="Date"
				archiveDateFormat="yyyyMMdd"
				maxArchiveFiles="365"
				keepFileOpen="false"
				layout="${layout}" />
		<!-- Blackhole for unwanted framework logs -->
		<target xsi:type="Null" name="blackhole" />
	</targets>

	<rules>
		<!-- 1) Microsoft/System DEBUG/INFO go to blackhole, never reach file -->
		<logger name="Microsoft.*" maxlevel="Info" writeTo="blackhole" final="true" />
		<logger name="System.*"     maxlevel="Info" writeTo="blackhole" final="true" />

		<!-- 2) Microsoft/System WARN+ go to file (real problems only) -->
		<logger name="Microsoft.*" minlevel="Warn" writeTo="file" final="true" />
		<logger name="System.*"     minlevel="Warn" writeTo="file" final="true" />

		<!-- 3) Your app logs (Debug+) -->
		<logger name="Rite.LeaveManagement.Svc.*"   minlevel="Debug" writeTo="file" />
		<logger name="LeaveManagementSystem.API.*"  minlevel="Debug" writeTo="file" />
	</rules>
</nlog>
